# Anthropic API key — required when LLM stubs are replaced with real calls
ANTHROPIC_API_KEY=your_key_here

# Search API key — required when web_search stub is replaced with a real search API
# Supported options: Tavily, Serper, Brave Search
SEARCH_API_KEY=your_key_here

# Optional: model to use for the Editor Agent (default: claude-sonnet-4-6)
EDITOR_MODEL=claude-sonnet-4-6

# Optional: model to use for the Fact-Check Evaluator (default: claude-sonnet-4-6)
EVALUATOR_MODEL=claude-sonnet-4-6

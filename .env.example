# Anthropic API key — required when LLM stubs are replaced with real calls
ANTHROPIC_API_KEY=your_key_here

# Search provider — controls which backend web_search uses
# Options: mock (default, deterministic), tavily
BLOGAGENT_SEARCH_PROVIDER=mock

# Tavily API key — required when BLOGAGENT_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# HTTP timeout in seconds for webpage_extract and Tavily search calls
BLOGAGENT_HTTP_TIMEOUT_SECONDS=15

# Maximum number of search results to fetch per query
BLOGAGENT_MAX_SEARCH_RESULTS=5

# Optional: model to use for the Editor Agent (default: claude-sonnet-4-6)
EDITOR_MODEL=claude-sonnet-4-6

# Optional: model to use for the Fact-Check Evaluator (default: claude-sonnet-4-6)
EVALUATOR_MODEL=claude-sonnet-4-6
